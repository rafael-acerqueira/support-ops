{
  "name": "supportops",
  "version": "0.1.0",
  "private": true,
  "description": "SupportOps is a customer support operations platform for B2B SaaS teams",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\" \"npm:dev:workers\"",
    "dev:web": "cd apps/web && pnpm run dev",
    "dev:api": "cd apps/api && uv run uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:workers": "cd apps/workers && uv run celery -A src.celery_app worker --loglevel=info",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test -- --watch",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.0.0",
    "turbo": "^1.10.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
